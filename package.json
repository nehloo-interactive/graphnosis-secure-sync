  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./crypto": "./dist/crypto/index.js",
    "./oplog": "./dist/oplog/index.js",
    "./federation": "./dist/federation/index.js",
    "./policy": "./dist/policy/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
